# --- Local dev (read by docker-compose.yml) ---------------------------------
DATABASE_URL=postgresql+psycopg://omniproctor:omniproctor@db:5432/omniproctor
SECRET_KEY=replace-with-a-strong-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=true
CORS_ORIGINS=["*"]

# --- Production overrides (read by docker-compose.prod.yml on the Azure VM) -
# Public URL the kiosk + browser must hit. Bake your VM's public DNS / IP here
# (e.g. https://omniproctor.example.com/api/v1 or http://20.123.45.67/api/v1).
# This is what the kiosk launch link uses, so it MUST be reachable from each
# student's PC, not just from inside the docker network.
API_BASE_URL=http://localhost:8001/api/v1

# Used by the SPA's runtime config (purely cosmetic in nginx logs).
APP_NAME=OmniProctor

# Postgres credentials. Rotate before going to production - the dev compose
# file uses "omniproctor" as both user and password by default.
POSTGRES_PASSWORD=omniproctor

# --- Kiosk-installer hosting -------------------------------------------------
# Two options:
#
#   1. Host the .exe on GitHub Releases (RECOMMENDED for production):
#      Set INSTALLER_WINDOWS_URL to the asset URL. The /downloads/installer/
#      windows endpoint then 307-redirects to GitHub instead of streaming a
#      local file, and the SPA opens the link directly. SHA-256 / size are
#      optional metadata - paste them from the GitHub release page so the
#      Downloads card can show them to students.
#
#   2. Drop the .exe into ./installers/ on the host (dev / air-gapped):
#      Leave INSTALLER_WINDOWS_URL unset. The endpoint streams the file at
#      ./installers/${INSTALLER_WINDOWS_FILENAME} via auth-required Bearer.
#
INSTALLER_WINDOWS_URL=
INSTALLER_WINDOWS_VERSION=0.1.0
INSTALLER_WINDOWS_FILENAME=OmniProctorKioskSetup.exe
# Optional - copy from the GitHub Releases page once published.
INSTALLER_WINDOWS_SHA256=
INSTALLER_WINDOWS_SIZE_BYTES=
